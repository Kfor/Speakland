# ============================================================
# Speakland Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Supabase ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- RevenueCat ---
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-revenuecat-ios-api-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-revenuecat-android-api-key

# --- AI / LLM API (OpenAI-compatible) ---
EXPO_PUBLIC_AI_API_BASE_URL=https://api.openai.com/v1
EXPO_PUBLIC_AI_API_KEY=your-openai-api-key
EXPO_PUBLIC_AI_MODEL=gpt-4o-mini

# --- Google OAuth (configured in Supabase Dashboard) ---
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Sentry (optional, for error monitoring) ---
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn
