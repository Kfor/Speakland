# Supabase
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# RevenueCat
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-revenuecat-ios-key
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-revenuecat-android-key

# Google Auth (for expo-auth-session)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-google-android-client-id

# --- Server-side only (Supabase Edge Function secrets) ---
# Set via: supabase secrets set LLM_API_KEY=xxx
# LLM_API_KEY=your-llm-api-key
# LLM_API_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL=openai/gpt-4o-mini
# SMART_ASSIST_MODEL=openai/gpt-4o-mini
